            <div class="row">
            </div>
        </div>
        <div class="card-footer">
            <a asp-action="Index" class="btn btn-sm btn-primary"><i class="fa fa-chevron-left"></i> Back</a>
            <button class="btn btn-sm btn-info" type="reset"><i class="fa fa-undo"></i> Reset</button>
            <button type="submit" class="btn btn-sm btn-success"><i class="fa fa-save"></i> Submit</button>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var csInputJsonMapping = {
            'label': ['CONTACT_GROUP', 'CONTACT_NAME', 'CONTACT_PERSON'],
            'value': 'CONTACT_NAME',
            'SB_MASTER_VM_CONTACT_ID': 'ID',
            'SB_MASTER_VM_CUSTOMER_REF_NO': 'CONTACT_PERSON',
        };
        autocompletesearch('/CRM/Contacts/FindCustomer', 3, 'SB_MASTER_VM_CONTACT_NAME', csInputJsonMapping);

        $("#SB_MASTER_VM_CONTACT_NAME").blur(function () {
            let contactId = $('#SB_MASTER_VM_CONTACT_ID').val();
            if (contactId) {

                $('#SB_MASTER_VM_CONTACT_ADDRESS_ID').val('');
                $('#SB_MASTER_VM_OFFICE_ADDRESS').val('');

                $.ajax({
                    url: `/CRM/Contacts/FindCustomerDefaultAddress?customerId=${contactId}`,
                    type: 'GET',
                    success: function (response) {
                        $('#SB_MASTER_VM_CONTACT_ADDRESS_ID').val(response.ID);
                        $('#SB_MASTER_VM_OFFICE_ADDRESS').val(response.OFFICE_ADDRESS);
                    },
                    error: function (error) {
                        console.error('Error fetching contact address:', error);
                    }
                });
            } else {
                alertify.error('Contact ID is not found');
            }
        });

        $(function () {
            $('#SB_MASTER_VM_LAST_SDD_DATE').datetimepicker();
            $('#SB_MASTER_VM_LAST_MFG_DATE').datetimepicker();
            $('#SB_MASTER_VM_LAST_DELIVERY_DATE').datetimepicker();
        });
    </script>
}

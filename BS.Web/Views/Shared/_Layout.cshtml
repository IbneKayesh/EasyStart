﻿@{
    var frm_area = ViewContext.RouteData.Values["area"]?.ToString();
    var frm_controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var frm_action = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] | BS</title>
    @{
        await Html.RenderPartialAsync("_CssPartial");
    }
</head>
<body class="hold-transition layout-top-nav">
    <div class="wrapper">
        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Content Header (Page header) -->
            <div class="content-header p-1 border-bottom border-dark">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            @Html.Raw(ViewBag.BackLink) @ViewData["Title"]
                        </div><!-- /.col -->
                        <div class="col-sm-6 text-right">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item">@(string.IsNullOrEmpty(frm_area) ? "ESBS" : @frm_area)</li>
                                <li class="breadcrumb-item">@frm_controller</li>
                                <li class="breadcrumb-item active">@frm_action > @ViewData["Title"]</li>
                            </ol>
                        </div><!-- /.col -->
                    </div><!-- /.row -->
                </div><!-- /.container-fluid -->
            </div>
            <!-- /.content-header -->
            <!-- Main content -->
            <div class="content mt-1">
                <div class="container-fluid">
                    @RenderBody()
                </div>
                <!-- /.container-fluid -->
            </div>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
    </div>
    <!-- ./wrapper -->
    <!-- REQUIRED SCRIPTS -->
    @{
        await Html.RenderPartialAsync("_JsPartial");
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
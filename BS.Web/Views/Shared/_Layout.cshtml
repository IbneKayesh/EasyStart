<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] | BS</title>
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="~/assets/plugins/fontawesome-free/css/all.min.css">
    <!-- Jquery UI -->
    <link href="~/assets/plugins/jquery-ui/jquery-ui.min.css" rel="stylesheet" />
    <link href="~/assets/plugins/select2/css/select2.min.css" rel="stylesheet" />
    <!-- DataTables -->
    <link rel="stylesheet" href="~/assets/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="~/assets/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
    <link rel="stylesheet" href="~/assets/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/assets/dist/css/adminlte.min.css">
    <style type="text/css">
        body {
            zoom: 95%;
            font-size: 16px;
        }

        .table-xs {
            font-size: 12px;
            font-family: "Arial Narrow", Arial, sans-serif;
        }

            .table-xs th {
                font-size: 11px;
                white-space: nowrap;
            }

            .table-xs td {
                font-size: 10px;
            }

            .table-xs td {
                padding: .1rem;
            }

        .table-ds {
            font-size: 10px;
            font-family: "Arial Narrow", Arial, sans-serif;
        }

            .table-ds th {
                font-size: 10px;
            }

            .table-ds td {
                font-size: 10px;
            }

        .action-list li {
            margin-bottom: 3px;
        }

        .control-label {
            font-size: 11px;
        }
        /* Define a base class for all input sizes (optional) */
        .custom-input {
            display: block;
            width: 100%;
            padding: 6px 12px; /* Adjust as needed */
            font-size: 12px; /* Adjust as needed */
            line-height: 1.42857143; /* Adjust as needed (matches Bootstrap default) */
            color: #555;
            background-color: #fff;
            background-clip: padding-box;
            border: 1px solid #ccc;
            border-radius: 3px; /* Adjust as needed */
            box-shadow: inset 0 1px 1px rgba(0, 0, 0, 0.075); /* Adjust as needed */
            transition: border-color ease-in-out .15s, box-shadow ease-in-out .15s;
        }
        /* Define the "xs" size class */
        .custom-input-xs {
            width: calc(100% - 1px); /* Adjust as needed for desired width */
            font-size: 12px; /* Adjust as needed */
            padding: 2px 2px; /* Adjust as needed */
        }

        .custom-input[readonly] {
            background-color: #f0f0f0; /* Gray background for read-only inputs */
        }

        .custom-input-xs[readonly] {
            background-color: #f0f0f0; /* Gray background for read-only inputs */
        }

        /* Change border color to light blue when form-control is focused */
        .custom-input:focus {
            border-color: rgba(30, 144, 255, 1) !important; /* Light blue border color */
            box-shadow: 0 0 5px rgba(30, 144, 255, 0.5) !important; /* Optional: light blue glow */
            outline: none; /* Remove default outline */
        }

        .custom-select-xs {
            padding: 2px 2px;
            width: calc(100% - 1px);
            height: 27px;
        }

    </style>


    <style type="text/css">
        .select2 {
            width: 98%;
        }

        .select2-container .select2-selection--single {
            height: 22px !important;
            display: flex !important;
            align-items: center !important;
            font-size: 11px !important;
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 22px !important;
            padding-left: 1px;
            font-size: 11px !important;
        }

        /* Select2 dropdown height */
        .select2-container .select2-dropdown {
            max-height: 200px !important;
            overflow-y: auto !important;
        }

        /* Select2 dropdown options height */
        .select2-container .select2-results__option {
            height: 22px !important;
            display: flex !important;
            align-items: center !important;
            font-size: 11px !important;
        }

    </style>
</head>

    <script type="text/javascript">
        //override defaults
        alertify.defaults.transition = "zoom";
        alertify.defaults.theme.ok = "btn btn-primary";
        alertify.defaults.theme.cancel = "btn btn-danger";
        alertify.defaults.theme.input = "form-control";
    </script>


    <script type="text/javascript" charset="utf-8">
        $(document).ready(function () {
            var url = window.location;
            $('ul.nav-treeview a').filter(function () {
                return this.href == url;
            }).addClass('active');
            $('ul.nav-sidebar a').filter(function () {
                return this.href == url;
            }).parent().parent().parent().addClass('menu-open').children('.nav-link').addClass('active');
        });
    </script>
    <script>
        $(document).scroll(function () {
            localStorage['page'] = document.URL;
            localStorage['scrollTop'] = $(document).scrollTop();
        });
        $(document).ready(function () {
            if (localStorage['page'] == document.URL) {
                $(document).scrollTop(localStorage['scrollTop']);
            }
        });
    </script>
    <script>
        $(document).ready(function () {
            var sidebarState = localStorage.getItem("sidebarState") || "closed";
            if (sidebarState === "closed") {
                $('body').removeClass('sidebar-collapse')
                $(window).trigger('resize')
            } else {
                $('body').addClass('sidebar-collapse')
                $(window).trigger('resize')
            }
            $("#sbsSideBar").click(function () {
                var sbState = $('body').hasClass('sidebar-collapse');
                if (sbState) {
                    localStorage.setItem("sidebarState", "closed");
                } else {
                    localStorage.setItem("sidebarState", "open");
                }
            });
        });
    </script>
    <script type="text/javascript">
        $(function () {
            //Initialize Select2 Elements
            $('.select2').select2();
        });
        //Sweet Alert
        @Html.Raw(TempData["msg"]);

        $(function () {
            $("#example1").DataTable({
                "responsive": true, "lengthChange": false, "autoWidth": false,
                "buttons": ["copy", "csv", "excel", "pdf", "print", "colvis"]
            }).buttons().container().appendTo('#example1_wrapper .col-md-6:eq(0)');
            $('#example2').DataTable({
                "paging": true,
                "lengthChange": false,
                "searching": true,
                "ordering": true,
                "info": true,
                "autoWidth": false,
                "responsive": true,
            });
        });
    </script>

    <script>
        $('#PartialPopModal').on('show.bs.modal', function (e) {
            var url = $(e.relatedTarget).data('url');
            var title = $(e.relatedTarget).data('title') || 'Modal Title';
            $('#PartialModalLabel').text(title);
            if (url) {
                $('#modalBodyId').load(url, function (response, status, xhr) {
                    if (status == "error") {
                        $('#modalBodyId').empty().append('<strong class="text-danger">Unable to fetch content</strong>');
                    }
                });
            }
        });
        $(document).ready(function () {
            $('#ModalSaveButton').click(function () {
                $('#partialForm').submit();
            });
        });
    </script>

    <script>
        //show confirmation message before submit
        $(document).ready(function () {
            $(".show-confirm").click(function () {
                var result = confirm("Are you sure?");
                if (result) {
                    var url = $(this).data('url');
                    window.location.href = url; // Reload the URL
                }
            });

            $(".delete-confirm").click(function () {
                var url = $(this).data('url');
                alertify.confirm('Delete', "Do you want to delete now?", function () {
                    $.get(url, function (data, status) {
                        if (data.success) {
                            $(this).parents("tr").remove();
                            //alertify.success(data.messages);
                            $.notify(data.messages, 'success');
                        } else {
                            $.notify(data.messages, 'error');
                            //alertify.error(data.messages);
                        }
                    });
                }, function () {
                    alertify.error('Cancel')
                })
            })
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>